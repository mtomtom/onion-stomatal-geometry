    "## Rename the files in the idealised folder\n",
    "\n",
    "import os\n",
    "import re\n",
    "\n",
    "# Set the directory path where your files are located\n",
    "directory = \"../Meshes/Idealised/pressure_results/\"  # Current directory - change this if files are elsewhere\n",
    "\n",
    "# Pattern to match files like: idealised_final_1_2_circular.ply_0.6 or idealised_final_1_2_oval.ply_0.6\n",
    "pattern = r'idealised_final_(.+?)_(circular|oval)\\.ply_(\\d+\\.\\d+)$'\n",
    "\n",
    "# Get all files in the directory\n",
    "files_to_rename = []\n",
    "for filename in os.listdir(directory):\n",
    "    match = re.match(pattern, filename)\n",
    "    if match:\n",
    "        mesh_id = match.group(1)\n",
    "        shape_type = match.group(2)  # circular or oval\n",
    "        number = match.group(3)\n",
    "        \n",
    "        # Create new filename: idealised_final_1_2_circular_0.6.ply\n",
    "        new_filename = f\"idealised_final_{mesh_id}_{shape_type}_{number}.obj\"\n",
    "        files_to_rename.append((filename, new_filename))\n",
    "\n",
    "# Show what will be renamed\n",
    "print(f\"Found {len(files_to_rename)} files to rename:\")\n",
    "for old, new in files_to_rename:\n",
    "    print(f\"  {old} -> {new}\")\n",
    "\n",
    "# Perform the renaming\n",
    "if files_to_rename:\n",
    "    confirm = input(f\"\\nProceed with renaming {len(files_to_rename)} files? (y/n): \")\n",
    "    if confirm.lower() == 'y':\n",
    "        for old_name, new_name in files_to_rename:\n",
    "            old_path = os.path.join(directory, old_name)\n",
    "            new_path = os.path.join(directory, new_name)\n",
    "            os.rename(old_path, new_path)\n",
    "            print(f\"Renamed: {old_name} -> {new_name}\")\n",
    "        print(\"All files renamed successfully!\")\n",
    "    else:\n",
    "        print(\"Renaming cancelled.\")\n",
    "else:\n",
    "    print(\"No files found matching the pattern.\")\n"
   ]
  },
